@model BoardGameReviews.Models.GameIndexViewModel

@{
    ViewData["Title"] = "Games";
}

<section class="game-page game-list-page">
    <div class="game-hero mb-4">
        <p class="eyebrow mb-2">BoardGameReviews</p>
        <h1 class="mb-2">Games</h1>
        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="status-banner mb-3">@Model.StatusMessage</div>
        }
    </div>

    <div id="games" class="entity-block game-table-wrap mb-4">
        <div class="entity-header">Games</div>
        <div class="list-toolbar">
            <div class="list-toolbar__search">
                <label class="form-label" for="game-search">Search</label>
                <input id="game-search"
                       class="form-control list-search-input"
                       type="search"
                       placeholder="Search by name, description, type, publisher, or category"
                       value="@Model.Search"
                       data-ajax-search
                       data-search-url="@Url.Action("Index", "Game")"
                       data-search-target="#games-table-body" />
            </div>
            <a class="btn game-btn-primary list-toolbar__action" asp-controller="Game" asp-action="Create">New Game</a>
        </div>
        <div class="table-responsive">
            <table class="table game-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Game</th>
                        <th>Year</th>
                        <th>Players</th>
                        <th>Difficulty</th>
                        <th>Type</th>
                        <th>Publisher</th>
                        <th>Category</th>
                        <th>Reviews</th>
                        <th>Avg. Rating</th>
                        <th>Events</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="games-table-body">
                    @await Html.PartialAsync("_GameTableRows", Model)
                </tbody>
            </table>
        </div>
    </div>
</section>