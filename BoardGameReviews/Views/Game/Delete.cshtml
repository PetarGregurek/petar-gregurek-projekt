@model BoardGameReviews.Models.GameDeleteViewModel

@{
    ViewData["Title"] = "Delete Game";
}

<section class="game-page game-delete-page">
    <div class="game-hero mb-4 d-flex justify-content-between align-items-start gap-3 flex-wrap">
        <div>
            <p class="eyebrow mb-2">Delete Game</p>
        </div>
        <a asp-controller="Game" asp-action="Index" class="btn game-btn-outline">Back to List</a>
    </div>

    <div class="game-card">
        <div class="card-header">Delete Confirmation</div>
        <div class="card-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <p><strong>@Model.Game.Name</strong> (@Model.Game.YearPublished)</p>
            <p class="mb-2">Reviews: @Model.ReviewCount</p>
            <p class="mb-4">Events: @Model.EventCount</p>

            @if (!Model.CanDelete)
            {
                <p class="text-danger mb-0">Delete is not allowed because this game has related reviews.</p>
            }
            else
            {
                <form asp-action="Delete" method="post">
                    <input type="hidden" name="id" value="@Model.Game.Id" />
                    <button type="submit" class="btn game-btn-danger">Confirm Delete</button>
                </form>
            }
        </div>
    </div>
</section>