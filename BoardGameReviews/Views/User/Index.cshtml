@model BoardGameReviews.Models.UserIndexViewModel

@{
    ViewData["Title"] = "Users";
}

<section class="game-page game-list-page">
    <div class="game-hero mb-4">
        <p class="eyebrow mb-2">BoardGameReviews</p>
        <h1 class="mb-2">Users</h1>
        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="status-banner mb-3">@Model.StatusMessage</div>
        }
    </div>

    <div id="users" class="entity-block game-table-wrap mb-4">
        <div class="entity-header">Users</div>
        <div class="list-toolbar">
            <div class="list-toolbar__search">
                <label class="form-label" for="user-search">Search</label>
                <input id="user-search"
                       class="form-control list-search-input"
                       type="search"
                       placeholder="Search by username, email, or country"
                       value="@Model.Search"
                       data-ajax-search
                       data-search-url="@Url.Action("Index", "User")"
                       data-search-target="#users-table-body" />
            </div>
            <a class="btn game-btn-primary list-toolbar__action" asp-action="Create">New User</a>
        </div>
        <div class="table-responsive">
            <table class="table game-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Country</th>
                        <th>Age</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="users-table-body">
                    @await Html.PartialAsync("_UserTableRows", Model)
                </tbody>
            </table>
        </div>
    </div>
</section>
