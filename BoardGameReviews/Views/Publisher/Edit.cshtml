@model BoardGameReviews.Models.PublisherFormViewModel

@{
    ViewData["Title"] = "Edit Publisher";
}

<section class="game-page game-form-page">
    <div class="game-hero mb-4 d-flex justify-content-between align-items-start gap-3 flex-wrap">
        <div>
            <p class="eyebrow mb-2">Edit Publisher</p>
        </div>
        <a asp-action="Index" class="btn game-btn-outline">Back to List</a>
    </div>

    <div class="game-card">
        <div class="card-header">Publisher Editing</div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input asp-for="Input.Id" type="hidden" />
                @await Html.PartialAsync("_PublisherForm", Model)
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
