@model BoardGameReviews.Models.GameTypeIndexViewModel

@{
    ViewData["Title"] = "Game Types";
}

<section class="game-page game-list-page">
    <div class="game-hero mb-4">
        <p class="eyebrow mb-2">BoardGameReviews</p>
        <h1 class="mb-2">Game Types</h1>
        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="status-banner mb-3">@Model.StatusMessage</div>
        }
    </div>

    <div id="gametypes" class="entity-block game-table-wrap mb-4">
        <div class="entity-header">Game Types</div>
        <div class="list-toolbar">
            <div class="list-toolbar__search">
                <label class="form-label" for="gametype-search">Search</label>
                <input id="gametype-search"
                       class="form-control list-search-input"
                       type="search"
                       placeholder="Search by name or description"
                       value="@Model.Search"
                       data-ajax-search
                       data-search-url="@Url.Action("Index", "GameType")"
                       data-search-target="#gametypes-table-body" />
            </div>
            <a class="btn game-btn-primary list-toolbar__action" asp-action="Create">New Game Type</a>
        </div>
        <div class="table-responsive">
            <table class="table game-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="gametypes-table-body">
                    @await Html.PartialAsync("_GameTypeTableRows", Model)
                </tbody>
            </table>
        </div>
    </div>
</section>
