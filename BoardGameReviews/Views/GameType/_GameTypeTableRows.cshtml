@model BoardGameReviews.Models.GameTypeIndexViewModel

@if (Model.GameTypes.Count == 0)
{
    <tr>
        <td colspan="3" class="text-secondary">No results found for the current query.</td>
    </tr>
}
else
{
    @foreach (var gt in Model.GameTypes)
    {
        <tr>
            <td><div class="fw-semibold">@gt.Name</div></td>
            <td>@gt.Description</td>
            <td>
                <div class="table-actions">
                    <a asp-action="Details" asp-route-id="@gt.Id" class="btn btn-sm game-btn-primary">Details</a>
                    <a asp-action="Edit" asp-route-id="@gt.Id" class="btn btn-sm game-btn-outline">Edit</a>
                    <a asp-action="Delete" asp-route-id="@gt.Id" class="btn btn-sm game-btn-danger">Delete</a>
                </div>
            </td>
        </tr>
    }
}
