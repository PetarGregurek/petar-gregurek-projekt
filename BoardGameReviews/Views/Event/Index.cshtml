@model BoardGameReviews.Models.EventIndexViewModel

@{
    ViewData["Title"] = "Events";
}

<section class="game-page game-list-page">
    <div class="game-hero mb-4">
        <p class="eyebrow mb-2">BoardGameReviews</p>
        <h1 class="mb-2">Events</h1>
        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="status-banner mb-3">@Model.StatusMessage</div>
        }
    </div>

    <div id="events" class="entity-block game-table-wrap mb-4">
        <div class="entity-header">Events</div>
        <div class="list-toolbar">
            <div class="list-toolbar__search">
                <label class="form-label" for="event-search">Search</label>
                <input id="event-search"
                       class="form-control list-search-input"
                       type="search"
                       placeholder="Search by name, game, or location"
                       value="@Model.Search"
                       data-ajax-search
                       data-search-url="@Url.Action("Index", "Event")"
                       data-search-target="#events-table-body" />
            </div>
            <a class="btn game-btn-primary list-toolbar__action" asp-action="Create">New Event</a>
        </div>
        <div class="table-responsive">
            <table class="table game-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Game</th>
                        <th>Start</th>
                        <th>End</th>
                        <th>Location</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="events-table-body">
                    @await Html.PartialAsync("_EventTableRows", Model)
                </tbody>
            </table>
        </div>
    </div>
</section>
